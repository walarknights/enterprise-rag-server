{
  "name": "enterprise-rag",
  "version": "0.1.0",
  "description": "企业知识库后端服务 - 基于 BM25 全文搜索的 RAG API",
  "productName": "企业知识库",
  "author": "NitroRCr <i@krytro.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src-server/index.ts",
    "test": "echo \"No test specified\" && exit 0",
    "dev:server": "bun run dev",
    "build": "bun build src-server/index.ts --target bun --outdir ./dist/server",
    "build:server": "bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "generate:auth": "bunx --bun @better-auth/cli@latest generate --config src-server/auth/auth.ts --output src-server/schema/auth.gen.ts -y"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "^1.5.4",
    "drizzle-orm": "^0.44.2",
    "fflate": "^0.8.2",
    "hono": "^4.9.11",
    "mammoth": "^1.11.0",
    "unpdf": "^1.3.2",
    "xlsx-republish": "^0.20.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/bun": "^1.1.14",
    "@types/node": "^20.5.9",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.14.0",
    "globals": "^15.12.0",
    "typescript": "~5.5.3",
    "typescript-eslint": "^8.43.0"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
